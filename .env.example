# ── Adresses ─────────────────────────────────────────────────────
PORT_BACKEND=8088
BACKEND_URL=http://localhost:8088
PORT_FRONTEND=4206
FRONTEND_URL=http://localhost:4206

# ── Base de données ──────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=devdb
DB_SCHEMA=restauration
DB_USER=devuser
DB_PASSWORD=CHANGE_ME

# ── Django ───────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME
DEBUG=False
ALLOWED_HOSTS=*

# ── Reverse proxy (Caddy) ────────────────────────────────────────
SCRIPT_NAME=/restauration-api

# ── SSO Keycloak ─────────────────────────────────────────────────
KEYCLOAK_CLIENT_ID=restauration
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/ssolab
# Client public (SPA Angular) — Keycloak → Clients → restauration → Access type : Public
# Valid redirect URIs : http://localhost:4206/*
# Service account pour la gestion des utilisateurs (créé/renseigné automatiquement
# par create-app-client.sh via restauration/.keycloak-service-account-roles) :
KEYCLOAK_ADMIN_CLIENT_ID=restauration-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=
# Optionnel : URL interne pour les appels admin (sinon base de KEYCLOAK_ISSUER_URI)
KEYCLOAK_ADMIN_BASE_URL=

# ── URLs (propagées automatiquement par reset_url.sh) ────────────
PORT_KEYCLOAK=8080
SERVER_URL_LAN=http://192.168.1.X
SERVER_URL_WAN=http://VOTRE_IP_WAN
KEYCLOAK_URL=http://192.168.1.X:8080
KEYCLOAK_PUBLIC_URL=http://VOTRE_IP_WAN:8080

# ── Email (envoi des factures) ───────────────────────────────────
# En DEBUG=True, les emails partent dans la console par défaut (aucun SMTP requis).
# Pour un envoi réel, renseigner un SMTP :
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@restauration.local

# ── Identité restaurant (en-tête de facture) + TVA ───────────────
RESTO_NOM=Mon Restaurant
RESTO_ADRESSE=
RESTO_SIRET=
RESTO_TVA_INTRA=
# Taux de TVA appliqué sur les factures (%). 10 = restauration sur place (France).
FACTURE_TVA_TAUX=10.0

# ── HTTPS / Caddy ─────────────────────────────────────────────────────────────
DOMAIN=CHANGE_ME
